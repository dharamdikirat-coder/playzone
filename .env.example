# Database Connection String (Direct PostgreSQL)
# Get this from Supabase Dashboard -> Project Settings -> Database -> Connection String
# IMPORTANT: URL-encode special characters in your password (e.g., @ becomes %40)
DATABASE_URL=

# Supabase Project Credentials
# Get these from Supabase Dashboard -> Project Settings -> API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: Custom Client-Side API Base URL
# Only needed when hosting the frontend on a separate service (like static Netlify)
# pointing to a custom backend URL (like your Vercel or Cloud Run service)
VITE_API_URL=
